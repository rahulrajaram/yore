#!/usr/bin/env bash
set -euo pipefail

COMMITHOOKS_DIR="$(cd "$(git rev-parse --git-common-dir)" && pwd)"
source "$COMMITHOOKS_DIR/lib/common.sh"
source "$COMMITHOOKS_DIR/lib/commit-msg.sh"

yore_validate_commit_message_body() {
  local msg_file="$1"
  local -a lines=()
  local subject=""
  local subject_idx=0
  local body_start_idx=-1
  local has_body=0
  local fail=0

  mapfile -t lines < <(grep -v '^#' "$msg_file" || true)

  for i in "${!lines[@]}"; do
    if [ -n "${lines[$i]}" ]; then
      subject="${lines[$i]}"
      subject_idx=$i
      break
    fi
  done

  if [ -z "$subject" ]; then
    commithooks_red "[commit-msg] Commit message cannot be empty."
    return 1
  fi

  for i in "${!lines[@]}"; do
    if [ "$i" -le "$subject_idx" ]; then
      continue
    fi

    if [ -n "$(printf '%s\n' "${lines[@]:$i}" | tr -d '[:space:]')" ]; then
      has_body=1
      for j in "${!lines[@]}"; do
        if [ "$j" -gt "$subject_idx" ] && [ -n "${lines[$j]}" ]; then
          body_start_idx=$j
          break
        fi
      done
      break
    fi
  done

  if [ "$has_body" -eq 1 ] && [ "$body_start_idx" -ne -1 ]; then
    local next_line_idx=$((subject_idx + 1))
    if [ "$next_line_idx" -lt "${#lines[@]}" ] && [ -n "${lines[$next_line_idx]}" ]; then
      commithooks_red "[commit-msg] Second line must be blank when body is present."
      fail=1
    fi

    for i in "${!lines[@]}"; do
      if [ "$i" -lt "$body_start_idx" ]; then
        continue
      fi

      local line="${lines[$i]}"
      if [ -n "$line" ] && ! printf '%s' "$line" | grep -qE 'https?://'; then
        if [ "${#line}" -gt 72 ]; then
          commithooks_red "[commit-msg] Body line $((i + 1)) exceeds 72 chars."
          fail=1
          break
        fi
      fi
    done
  fi

  return "$fail"
}

msg_file="$1"
subject="$( { grep -v '^#' "$msg_file" || true; } | sed -n '/./{p;q;}')"
if printf '%s' "$subject" | grep -qE '^Revert '; then
  exit 0
fi

export COMMITHOOKS_CC_TYPES="${COMMITHOOKS_CC_TYPES:-feat,fix,docs,style,refactor,test,chore,perf,ci,build,revert,yarli,handoff}"

commithooks_validate_conventional_commit "$msg_file"
commithooks_validate_subject_line "$msg_file"
yore_validate_commit_message_body "$msg_file"
